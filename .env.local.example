# ── Appwrite Cloud ──────────────────────────────────────────────
# Create a project at https://cloud.appwrite.io and copy the IDs here.
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id

# Database + collections (Stage 1 uses these two)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=tsp_main
NEXT_PUBLIC_APPWRITE_LEADS_COLLECTION_ID=lead_requests
NEXT_PUBLIC_APPWRITE_EXPERTS_COLLECTION_ID=experts
NEXT_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=profiles
NEXT_PUBLIC_APPWRITE_CONTACTS_COLLECTION_ID=contacts
NEXT_PUBLIC_APPWRITE_ORDERS_COLLECTION_ID=orders

# Storage bucket for expert avatars
NEXT_PUBLIC_APPWRITE_EXPERTS_BUCKET_ID=experts

# The owner email is auto-promoted to admin role on registration/login.
NEXT_PUBLIC_OWNER_EMAIL=musadiqqureshi@gmail.com

# OAuth redirect (set to your deployed URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Server-only secrets (used by Appwrite Functions, NOT exposed) ─
# Configure these inside Appwrite Function environment variables.
# RESEND_API_KEY=...
# GEMINI_API_KEY=...
# APPWRITE_API_KEY=...
